generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Barber {
  id        String    @id @default(cuid())
  name      String
  bio       String?
  image     String?
  active    Boolean   @default(true)
  bookings  Booking[]
  createdAt DateTime  @default(now())
}

model Service {
  id          String    @id @default(cuid())
  name        String
  description String?
  category    String    // "Cuts", "Beard", "Kids", "Specials", "Add-ons", "SMP"
  price       Float
  duration    Int       // minutes
  image       String?
  active      Boolean   @default(true)
  bookings    Booking[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  stock       Int         @default(0)
  active      Boolean     @default(true)
  category    String      @default("General") // "Grooming", "Styling", "Skincare"
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  clientName    String
  clientPhone   String
  total         Float
  status        String      @default("pending") // pending, paid, fulfilled
  stripePaymentId String?
  bookingId     String?
  createdAt     DateTime    @default(now())
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  price     Float
}

model Booking {
  id                String   @id @default(cuid())
  clientName        String
  clientEmail       String
  clientPhone       String
  serviceId         String
  service           Service  @relation(fields: [serviceId], references: [id])
  barberId          String?
  barber            Barber?  @relation(fields: [barberId], references: [id])
  date              DateTime
  startTime         String   // "10:00"
  endTime           String   // "10:30"
  status            String   @default("pending_payment") // pending_payment, confirmed, cancelled, completed, no-show
  notes             String?
  deposit           Float?
  depositPaid       Boolean  @default(false)
  stripePaymentId   String?
  reminderSentAt    DateTime?
  noShowCount       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  review            Review?
}

model WaitlistEntry {
  id          String   @id @default(cuid())
  clientName  String
  clientPhone String
  clientEmail String
  serviceId   String
  barberId    String?
  date        DateTime
  preferredTime String? // "morning", "afternoon", "any"
  status      String   @default("waiting") // waiting, notified, booked, expired
  notifiedAt  DateTime?
  createdAt   DateTime @default(now())
}

model SmsLog {
  id        String   @id @default(cuid())
  phone     String
  message   String
  type      String   // "reminder", "confirmation", "cancellation"
  status    String   @default("sent") // sent, failed
  bookingId String?
  createdAt DateTime @default(now())
}

model BlockedSlot {
  id        String   @id @default(cuid())
  date      DateTime
  startTime String
  endTime   String
  reason    String?  // "lunch", "holiday", "personal"
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  category  String?  // "fades", "beards", "lineups", "kids", "smp"
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LoyaltyVisit {
  id          String   @id @default(cuid())
  clientPhone String
  visitDate   DateTime @default(now())
  redeemed    Boolean  @default(false)
}

model Settings {
  id              String @id @default("default")
  shopName        String @default("Timz Trimz")
  openTime        String @default("09:00")
  closeTime       String @default("19:00")
  slotInterval    Int    @default(30) // minutes
  daysOff         String @default("Sunday") // comma-separated
  depositRequired Float  @default(0)
}
